<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Admin Movies</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">
    <%- include('../partials/sidebar') %>

    <div class="ml-64 p-6">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-3xl font-bold">Movies</h1>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            <% movies.forEach(movie => { %>
                <div class="bg-white rounded-xl shadow hover:shadow-xl overflow-hidden">
                    <img 
                        src="<%= movie.movieImage || 'https://via.placeholder.com/300x400' %>"
                        class="w-full h-60 object-cover"
                        alt="<%= movie.title %>"
                    >

                    <div class="p-4">
                        <h2 class="font-bold text-lg"><%= movie.title %></h2>

                        <p class="text-sm text-gray-600">
                            <%= movie.genre ? movie.genre.join(', ') : '' %>
                        </p>

                        <p class="text-sm text-gray-600">
                            <%= movie.language %>
                        </p>

                        <p class="text-sm text-gray-600 mb-3">
                            <%= movie.duration %> min
                        </p>

                        <div class="flex justify-between items-center gap-2">
                            <a href="/admin/movie/edit/<%= movie._id %>"
                               class="bg-blue-500 text-white px-3 py-1 rounded">
                                Edit
                            </a>

                            <form action="/admin/movie/delete/<%= movie._id %>" method="POST">
                                <button type="submit"
                                    onclick="return confirm('Delete movie?')"
                                    class="bg-red-500 text-white px-3 py-1 rounded">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</body>
</html>